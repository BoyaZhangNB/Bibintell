{
  "manifest_version": 3,
  "name": "Bibintell",
  "version": "1.0",
  "description": "AI focus beaver that helps you stay productive.",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": ["<all_urls>", "http://127.0.0.1:8000/*"],
  "background": {
    "service_worker": "background/background.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["bibin_assets/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/content.js",
        "pet/animation.js",
        "pet/pet-container.js"
      ],
      "css": ["pet/pet.css"],
      "run_at": "document_idle"
    }
  ]
}